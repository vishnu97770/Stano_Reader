# Stano_Reader — environment variable reference
# Copy this file to .env and fill in your values.
# The backend reads variables from backend/.env automatically via pydantic-settings.

# ── Backend ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins (JSON array string)
CORS_ORIGINS=["http://localhost:5173"]

# Enable FastAPI debug mode (auto-reload, verbose errors)
DEBUG=true

# ── Ollama (local LLM — optional, M17 AI refinement) ──────────────────────────
# Ollama must be running locally: https://ollama.ai
# The AI refinement layer is skipped silently when Ollama is not reachable.
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=3.0

# ── Docker overrides ───────────────────────────────────────────────────────────
# When running inside Docker, the backend cannot reach host's localhost.
# Override Ollama URL to use the host network:
# OLLAMA_URL=http://host.docker.internal:11434/api/generate
